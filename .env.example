# WPS 开放平台 — 企业自建应用
WPS_CLIENT_ID=your_app_id
WPS_CLIENT_SECRET=your_app_secret

# OAuth 本地回调（需在开放平台「安全配置 → 授权回调地址」中配置相同地址，不是「事件与回调」）
WPS_REDIRECT_URI=http://127.0.0.1:38473/callback
WPS_OAUTH_PORT=38473

# OAuth scope（须与权限管理中已开通的 scope 一致；新增 scope 后需重新登录）
# V1.3 云文档链接附件需 drive + file + file_link
WPS_OAUTH_SCOPES=kso.user_base.read,kso.mailbox.read,kso.mail.readwrite,kso.drive.readwrite,kso.file.readwrite,kso.file_link.readwrite

# 云文档分享链接（V1.3，可选）
# WPS_CLOUD_LINK_SCOPE=company
# WPS_CLOUD_LINK_ROLE_ID=viewable
# WPS_CLOUD_LINK_EXPIRE_DAYS=0
# WPS_CLOUD_DOC_URL=https://365.kdocs.cn/latest

# WPS 365 Web 邮箱页面（「在浏览器中打开」）
# WPS_WEB_MAIL_URL=https://365.kdocs.cn/email/
# Web 邮箱后端 API（F12 可见：email.wps.cn/api/v1|v2/...，与页面域名不同）
# WPS_WEB_MAIL_API_BASE=https://email.wps.cn

# 写信自动追加签名（支持简单 HTML，如 <br>换行）
# WPS_MAIL_SIGNATURE=张三<br>WPS 365 邮箱

# 可选
# WPS_API_BASE=https://openapi.wps.cn
# WPS_OAUTH_AUTH_URL=https://openapi.wps.cn/oauth2/auth
# WPS_OAUTH_TOKEN_URL=https://openapi.wps.cn/oauth2/token
